GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=your-gemini-api-key-here

# Firebase / GCP
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIRESTORE_PROJECT_ID=your-gcp-project-id
FIREBASE_SERVICE_ACCOUNT=path/to/service-account.json  # optional; ADC used on Cloud Run

# Google OAuth (Gmail + Calendar)
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-backend.run.app/auth/callback

# GCS file storage
GCS_BUCKET_NAME=your-bucket-name

# Optional
PORT=8080
ELORA_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
ELORA_COMPUTER_USE_MODEL=gemini-2.5-computer-use-preview

# LiveKit (for voice calls)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# MemU Proactive Memory Engine (OPEN SOURCE - Apache 2.0)
# https://github.com/NevaMind-AI/memU
#
# OPTION 1: Self-hosted with Google Gemini (FREE, recommended for hackathon)
# Uses the same GOOGLE_API_KEY as Elora - no new keys needed!
MEMU_CLOUD=false
# GOOGLE_API_KEY is already set above for Gemini

# OPTION 2: MemU Cloud (convenience, free tier available)
# MEMU_API_KEY=your-api-key  # Get from https://memu.so
# MEMU_CLOUD=true
