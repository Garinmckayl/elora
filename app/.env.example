# Expo / React Native frontend environment variables
# Copy to .env.local and fill in your values.
# All EXPO_PUBLIC_* vars are bundled into the app at build time (not secret).

# Backend URL (your Cloud Run service)
EXPO_PUBLIC_ELORA_BACKEND=https://your-backend.run.app

# Firebase Web SDK config (get from Firebase Console > Project Settings > Web app)
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Google OAuth client IDs (get from Google Cloud Console > Credentials)
# Web client ID is required for Firebase Google Sign-In
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# Optional: platform-specific client IDs for native flows
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
